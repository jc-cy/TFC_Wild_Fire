    {
      "var.fly_rarmrx": "torad(-7*sin( var.lsF )*limb_speed +30*var.speed_drag*(var.forwd_drag+max(0,-var.sidwd_drag*var.strafe)/2) -70*clamp(var.yaw_speed/2,-1,1) -60*clamp(var.speed_speed*4*var.forwd_drag,-1,1) )*max(0,1 -var.rswingingA -var.raction )*var.flying",
      "var.fly_larmrx": "torad(-7*cos( var.lsF )*limb_speed +30*var.speed_drag*(var.forwd_drag+max(0, var.sidwd_drag*var.strafe)/2) +70*clamp(var.yaw_speed/2,-1,1) -60*clamp(var.speed_speed*4*var.forwd_drag,-1,1) )*max(0,1 -var.lswingingA -var.laction )*var.flying",
      "var.fly_rarmry": "torad( 10 -20*clamp(var.yaw_speed/2,-1,1) )*max(0,1 -var.rswingingA -var.raction )*var.flying",
      "var.fly_larmry": "torad(-10 -20*clamp(var.yaw_speed/2,-1,1) )*max(0,1 -var.lswingingA -var.laction )*var.flying",
      "var.fly_rarmrz": "torad( 10-12*var.speed_speed +3*cos(-pi/6*sin(var.lsF)*(1-limb_speed) +var.Bt ) +50*clamp(abs(var.yaw_speed)/2,0,1) -min(0,20*var.speed_drag*var.sidwd_drag*var.strafe) )*var.flying",
      "var.fly_larmrz": "torad(-10+12*var.speed_speed -3*cos( pi/6*sin(var.lsF)*(1-limb_speed) +var.Bt ) -50*clamp(abs(var.yaw_speed)/2,0,1) -max(0,20*var.speed_drag*var.sidwd_drag*var.strafe) )*var.flying",
