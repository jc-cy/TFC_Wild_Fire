    {
      "var.fly_rlegrx": "torad( 5+8*cos( pi/6*sin(var.lsF/1.2)*(1-limb_speed) +var.Bt ) +7*sin( pi/6*sin(var.lsF/5)*0 +var.lsF )*limb_speed -3*var.fly_rlegty +25*var.speed_drag*(var.forwd_drag+abs(var.sidwd_drag*var.strafe)/2) +(22+30*limb_speed)*clamp(var.yaw_speed/2,-1,1) )*var.flying",
      "var.fly_llegrx": "torad( 5+8*cos(-pi/6*sin(var.lsF/1.2)*(1-limb_speed) +var.Bt ) +7*cos(-pi/6*sin(var.lsF/5)*0 +var.lsF )*limb_speed -3*var.fly_llegty +25*var.speed_drag*(var.forwd_drag+abs(var.sidwd_drag*var.strafe)/2) -(22+30*limb_speed)*clamp(var.yaw_speed/2,-1,1) )*var.flying",
      "var.fly_rlegry": "torad( 4*(1-var.idle) )*var.flying",
      "var.fly_llegry": "torad(-4*(1-var.idle) )*var.flying",
      "var.fly_rlegrz": "torad( (15+20*limb_speed)*clamp(var.yaw_speed/2,-1,1) -20*var.speed_drag*var.sidwd_drag*var.strafe )*var.flying",
      "var.fly_llegrz": "torad( (15+20*limb_speed)*clamp(var.yaw_speed/2,-1,1) -20*var.speed_drag*var.sidwd_drag*var.strafe )*var.flying",
      "var.fly_rlegtx": "0",
      "var.fly_llegtx": "0",
      "var.fly_rlegty": "var.fly_bodyty +( -(1-sin(var.ls/3+cos(var.ls/3)*var.idle))*(1-0.9*limb_speed) +( min(0, var.forwd_drag ) +2*min(0,-var.sidwd_drag) )*limb_speed )*var.flying",
      "var.fly_llegty": "var.fly_bodyty +( -(1+sin(var.ls/3-cos(var.ls/3)*var.idle))*(1-0.9*limb_speed) +( min(0, var.forwd_drag ) +2*min(0, var.sidwd_drag) )*limb_speed )*var.flying",
      "var.fly_rlegtz": "var.fly_rlegty-var.fly_bodyty +( min(0, var.forwd_drag ) +2*min(0,-var.sidwd_drag) )*limb_speed*var.flying",
      "var.fly_llegtz": "var.fly_llegty-var.fly_bodyty +( min(0, var.forwd_drag ) +2*min(0, var.sidwd_drag) )*limb_speed*var.flying"
    },
    {
      "var.eqp_rarmrx": "(-pi/10*(1+var.sneak)*(1-pow(var.gfast,2)))*(1-cos(var.requip*pi))/2+torad((-90*cos(swing_progress*pi)*var.attA+(head_pitch-0.7))*var.rswingingA+(-18*var.attC+10*var.idle)*var.lswingingA)+torad(-65)*var.rholdtorch*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)+torad(-85)*var.rholdlantern*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)",
      "var.eqp_rarmry": "torad(((-15+25*cos(swing_progress*pi))*var.attA-10*var.idle+var.hy/1.5*if(is_riding,0.5,1))*var.rswinging-(-10*var.attC-10*var.idle)*var.lswinging)+torad(16)*var.rholdtorch*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)+torad(16)*var.rholdlantern*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)",
      "var.eqp_rarmrz": "torad((-20*sin((1-swing_progress)*pi)*var.attA+5)*var.rswinging-(-5)*var.lswinging)+torad(6)*var.rholdtorch*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)+torad(6)*var.rholdlantern*if(is_using_item,0,1)*var.requip_torch*(1-var.torch_fall)",
      "var.eqp_larmrx": "(-pi/10*(1+var.sneak)*(1-pow(var.gfast,2)))*(1-cos(var.lequip*pi))/2+torad((-90*cos(swing_progress*pi)*var.attA+(head_pitch-0.7))*var.lswingingA+(-18*var.attC+10*var.idle)*var.rswingingA)+torad(-65)*var.lholdtorch*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)+torad(-85)*var.lholdlantern*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)",
      "var.eqp_larmry": "torad(-((-15+25*cos(swing_progress*pi))*var.attA-10*var.idle+var.hy/1.5*if(is_riding,0.5,1))*var.lswinging+(-10*var.attC-10*var.idle)*var.rswinging)+torad(-16)*var.lholdtorch*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)+torad(-16)*var.lholdlantern*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)",
      "var.eqp_larmrz": "torad(-(-20*sin((1-swing_progress)*pi)*var.attA+5)*var.lswinging+(-5)*var.rswinging)+torad(-6)*var.lholdtorch*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)+torad(-6)*var.lholdlantern*if(is_using_item,0,1)*var.lequip_torch*(1-var.torch_fall)",
      "var.eqp_rarmtz": "(-0.4)*var.requip+((2+2*cos(swing_progress*pi)*var.attA)*(var.rswingingA-var.lswingingA))*var.rspearhold",
      "var.eqp_larmtz": "(-0.4)*var.lequip+((2+2*cos(swing_progress*pi)*var.attA)*(var.lswingingA-var.rswingingA))*var.lspearhold",
      "var.mvmnt_rarmrx": "var.mvmnt_rarmrx*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)",
