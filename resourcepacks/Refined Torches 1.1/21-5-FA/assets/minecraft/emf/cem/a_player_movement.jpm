{
  "credit": "Created by FreshLX for Fresh Animations, Edited by patovskiz for Refined Torches",
  "id": "player_movement",
  "animations": [
    {
      "var.mvmnt_bodyrx": "torad( 20*(1-0.7*var.wade) +(20 -5*cos(var.ls*2))*var.walk )*clamp(var.sneak+var.wade/1.5, 0, 1-var.in_air/3)       +torad(  2*cos(var.ls*2) +10*var.sprint +7*var.forwd_drag        +5*abs(var.sidwd_drag)*var.strafe )*      sqrt(limb_speed)*(var.walk/2 +var.run/2)        +torad(-25 +( 5                     )*(0.5+0.7*var.crawl) )*var.prone",
      "var.mvmnt_bodyry": "                                                                                                                     torad( 13*cos(var.ls  )*(1            +0.2*var.sprint-0.3*var.wade)*(1-var.laying)                )*clamp(sqrt(limb_speed)* var.walk, 0.5*var.idle, 1)    +torad(    -(12*cos( pi/7  +var.lsc))*(0.5+0.7*var.crawl) )*var.prone",
      "var.mvmnt_bodyrz": "torad(                                          -2*sin(var.ls                   )*(1-var.run) *var.walk)*var.sneak  +torad( -3*sin(var.ls  )*(1-0.5*var.run+0.6*var.sprint-0.3*var.wade) -5*var.sidwd_drag *var.strafe )*      sqrt(limb_speed)* var.walk                      +torad(    -(-4*cos(        var.lsc))*(0.5+0.7*var.crawl) )*var.prone",
      "var.mvmnt_bodytx": "(                                                 -cos(var.ls                   )*(1-var.run) *var.walk)*clamp(var.sneak*(1-var.climb)+var.wade/3, 0, 1-var.in_air/3  )  +( -cos(     var.ls)/2.6*var.mforward*(1+var.sprint) )*sqrt(limb_speed)*var.run*(1-var.jump/2*var.sprint)                                                                                   -(      (    0.5*cos(pi/7 +var.lsc                         ))*(0.5+0.7*var.crawl)              )*var.prone +( var.sidwd_drag*var.sneak )*var.walk*var.strafe",
      "var.mvmnt_bodyty": "(4*(1-0.7*clamp(var.wade-var.walk, 0, 1))  -2                                                 *var.walk)*clamp(var.sneak*(1-var.climb)+var.wade/2, 0, 1-var.in_air/1.5) +( sin(pi/4+var.ls*2 -cos(pi/4+var.ls*2)/6) +0.8 )*0.8*var.walk*(1-var.sneak/3)*(1-var.run)*(1-var.in_air) +( -cos(pi/4+var.ls*2 -cos(var.ls*2)/4) )*sqrt(limb_speed)*var.run*(1-var.in_air) +( 1.5 +(0.6+0.6*cos(pi/9 +var.lsc*2-cos(pi/9 +var.lsc*2)/3))*(0.5+0.7*var.crawl)              )*var.prone",
      "var.mvmnt_bodytz": "(2*(1-0.7*clamp(var.wade-var.walk, 0, 1)) +(2 -0.5*sin(var.ls*2 -cos(var.ls*2)/3)*(1-var.run))*var.walk)*clamp(var.sneak*(1-var.climb)+var.wade/2, 0, 1-var.in_air/3  )   +(-2*var.walk)*var.wade                                                                                                                                                                    +(-0.5 +(  1+0.3*sin(      var.lsc*2                       ))*(0.5+0.7*var.crawl) -3*var.climb )*var.prone +var.sneak",
      "var.mvmnt_headrx": "torad(5*var.walk)*var.sneak    +torad(-60*(1-var.climb/2) +( 15 +3*sin(var.lsc*2))*(0.5+0.7*var.crawl) )*var.prone",
      "var.mvmnt_headry": "  torad(-25*var.sidwd_drag )*var.walk*var.strafe   +torad( (    -3*cos(var.lsc  ))*(0.5+0.7*var.crawl) )*var.prone +( sin((torad(var.hy)-var.climb_direction) -sin((torad(var.hy)-var.climb_direction)*2)/6 )*1.5 )*var.climb",
      "var.mvmnt_headrz": "0",
      "var.mvmnt_headtx": "0",
      "var.mvmnt_headty": "( 1 )*var.sneak",
      "var.mvmnt_headtz": "(-1 )*var.prone"
    },
    {
      "var.mvmnt_rarmrx": "torad(   60*cos(pi/7+var.ls)*(1-0.2*var.walk +0.2*var.sprint) +10*var.mforward -10*var.wade                                                        ) *sqrt(limb_speed)*var.walk                                                *(1-var.rblock-var.lblock/2)*(1-var.in_air/3  )*(1-var.requip/(2+0.8*var.sprint))  +torad(-30*(1-var.rswingingA))*var.wade*(1-var.raction-var.laction/1.5)  +torad(-135 -(-5 +12*cos(var.lsc +cos(var.lsc)/2) -10*sin(var.lsc +cos(var.lsc) ) )*(0.5+0.7*var.crawl) +sin(var.Bt) )*var.prone",
      "var.mvmnt_larmrx": "torad(  -60*cos(pi/7+var.ls)*(1-0.2*var.walk +0.2*var.sprint) +10*var.mforward -10*var.wade                                                        ) *sqrt(limb_speed)*var.walk                                                *(1-var.lblock-var.rblock/2)*(1-var.in_air/3  )*(1-var.lequip/(2+0.8*var.sprint))  +torad(-30*(1-var.lswingingA))*var.wade*(1-var.laction-var.raction/1.5)  +torad(-135 -(-5 -12*cos(var.lsc -cos(var.lsc)/2) +10*sin(var.lsc -cos(var.lsc) ) )*(0.5+0.7*var.crawl) +sin(var.Bt) )*var.prone",
      "var.mvmnt_rarmry": "torad( ( 18*cos(     var.ls) -10*(0.8+cos(-1.3+var.ls -sin(-1.3+var.ls)/1.5)) )*(1+var.sprint)/2*(1-var.fall) +( 5 -10*cos(pi/3+var.ls))*var.sneak )*(sqrt(limb_speed)*var.walk+var.idle)*(1-var.prone-var.sit)*(1-var.gliding)*(1-var.rblock-var.lblock  )*(1-var.in_air/1.5)*(1-var.requip/(2+0.8*var.sprint))  +torad( 15*(1-var.rswingingA))*var.wade*(1-var.raction-var.laction/1.5)  +torad(  3  -(    4 *sin(var.lsc +cos(var.lsc)  )  -4*cos(-pi/6 +var.lsc)         )*(0.5+0.7*var.crawl)              )*var.prone",
      "var.mvmnt_larmry": "torad( ( 18*cos(     var.ls) +10*(0.8-cos(-1.3+var.ls +sin(-1.3+var.ls)/1.5)) )*(1+var.sprint)/2*(1-var.fall) +(-5 -10*cos(pi/3+var.ls))*var.sneak )*(sqrt(limb_speed)*var.walk+var.idle)*(1-var.prone-var.sit)*(1-var.gliding)*(1-var.lblock-var.rblock  )*(1-var.in_air/1.5)*(1-var.lequip/(2+0.8*var.sprint))  +torad(-15*(1-var.lswingingA))*var.wade*(1-var.laction-var.raction/1.5)  +torad( -3  -(    4 *sin(var.lsc -cos(var.lsc)  )  -4*cos(-pi/6 +var.lsc)         )*(0.5+0.7*var.crawl)              )*var.prone",
      "var.mvmnt_rarmrz": "torad( 2 +6*var.sprint +4*cos(pi/5+var.ls)                                                                    +( 9 +10*cos(     var.ls))*var.sneak ) *sqrt(limb_speed)*var.walk                                                                                               *(1-var.requip/(2+0.8*var.sprint))  +torad( 25*(1-var.rswingingA))*var.wade*(1-var.raction-var.laction/1.5)",
      "var.mvmnt_larmrz": "torad(-2 -6*var.sprint +4*cos(pi/5+var.ls)                                                                    +(-9 +10*cos(     var.ls))*var.sneak ) *sqrt(limb_speed)*var.walk                                                                                               *(1-var.lequip/(2+0.8*var.sprint))  +torad(-25*(1-var.lswingingA))*var.wade*(1-var.laction-var.raction/1.5)",
      "var.mvmnt_rarmtx": "( ( 0.5+cos(var.ls*2                            ))/4 )*sqrt(limb_speed)*var.sprint                  *(1-var.requip/2)    +(-0.7*(1-var.rswingingA))*var.wade",
      "var.mvmnt_larmtx": "( (-0.5-cos(var.ls*2                            ))/4 )*sqrt(limb_speed)*var.sprint                  *(1-var.requip/2)    +( 0.7*(1-var.lswingingA))*var.wade",
      "var.mvmnt_rarmty": "                                                                                                                                                                   (-0.5 -(    cos(var.lsc +cos(var.lsc)/2.5 ) +0.6*cos(pi/9 +var.lsc*2-cos(pi/9 +var.lsc*2)/3) )*(0.5+0.7*var.crawl) -sin(var.Bt)/2.5 )*var.prone",
      "var.mvmnt_larmty": "                                                                                                                                                                   (-0.5 -(   -cos(var.lsc -cos(var.lsc)/2.5 ) +0.6*cos(pi/9 +var.lsc*2-cos(pi/9 +var.lsc*2)/3) )*(0.5+0.7*var.crawl) -sin(var.Bt)/2.5 )*var.prone",
      "var.mvmnt_rarmtz": "(  2*cos(var.ls -sin(var.ls)/3*(0.3+0.7*var.sprint)) )*sqrt(limb_speed)*var.walk *(1-var.in_air/1.5)*(1-var.requip/2) *(1-var.rblock-var.lblock-var.rspearhold)   +(-1   +(0.5-cos(var.lsc +cos(var.lsc)/2.5 )                                                  )*var.crawl                            )*var.prone",
      "var.mvmnt_larmtz": "( -2*cos(var.ls +sin(var.ls)/3*(0.3+0.7*var.sprint)) )*sqrt(limb_speed)*var.walk *(1-var.in_air/1.5)*(1-var.lequip/2) *(1-var.lblock-var.rblock-var.lspearhold)   +(-1   +(0.5+cos(var.lsc -cos(var.lsc)/2.5 )                                                  )*var.crawl                            )*var.prone"
    },
    {
      "var.mvmnt_rlegrx": "(torad( 10*var.sprint +20*(0.67+0.33*var.mforward) -60*cos(var.ls +cos(var.ls)/4  ) )*sqrt(limb_speed)*var.run*(1-var.in_air/3)  +torad( 13*(1-var.sneak/2)*(1-var.idle) -40*cos(var.ls +cos(var.ls)/2.5 ) )*clamp(var.walk, 0.1*var.idle+0.3*var.sneak-0.07*var.laying, 1)*max(0,1-var.run-var.in_air/2-var.gliding) ) +torad(-3 +(-3 -5*cos(pi/4 +var.lsc +sin(      var.lsc)/1.3))*         var.crawl  )*var.prone",
      "var.mvmnt_llegrx": "(torad( 10*var.sprint +20*(0.67+0.33*var.mforward) +60*cos(var.ls -cos(var.ls)/4  ) )*sqrt(limb_speed)*var.run*(1-var.in_air/3)  +torad( 13*(1-var.sneak/2)*(1-var.idle) +40*cos(var.ls -cos(var.ls)/2.5 ) )*clamp(var.walk, 0.1*var.idle+0.3*var.sneak-0.07*var.laying, 1)*max(0,1-var.run-var.in_air/2-var.gliding) ) +torad(-3 +(-3 +5*cos(pi/4 +var.lsc -sin(      var.lsc)/1.3))*         var.crawl  )*var.prone",
      "var.mvmnt_rlegry": "-var.root_rz*2*clamp( cos(var.ls)-0.5 -var.yaw_speed*2, 0, 1)*var.walk                                                                                                                                                                                                                                                  +torad( 3 +( 5 +9*sin(pi/6 +var.lsc -cos(pi/6 +var.lsc)    ))*(0.5+0.7*var.crawl) )*var.prone  +torad( 20*max(0, var.sidwd_drag) )*var.walk*var.strafe",
      "var.mvmnt_llegry": "-var.root_rz*2*clamp(-cos(var.ls)-0.5 +var.yaw_speed*2, 0, 1)*var.walk                                                                                                                                                                                                                                                  +torad(-3 +(-5 +9*sin(pi/6 +var.lsc +cos(pi/6 +var.lsc)    ))*(0.5+0.7*var.crawl) )*var.prone  +torad(-20*max(0,-var.sidwd_drag) )*var.walk*var.strafe",
      "var.mvmnt_rlegrz": "-var.root_rz  *clamp( cos(var.ls)-0.5 -var.yaw_speed*2, 0, 1)*var.walk  +torad(  1 -6*cos(var.ls -cos(var.ls)/1.3) )*sqrt(limb_speed)*(0.5*var.run+0.5*var.sprint)  +torad( 1 +( 3-5*sin(var.ls +cos(var.ls)     ) )*var.walk )*var.sneak                                                                               +torad(    (   -2*sin(      var.lsc -cos(      var.lsc)    ))*(0.5+0.7*var.crawl) )*var.prone  +(-var.mvmnt_rlegrx/2 -torad(2)*abs(var.sidwd_drag) )*var.sidwd_drag*var.walk*var.strafe",
      "var.mvmnt_llegrz": "-var.root_rz  *clamp(-cos(var.ls)-0.5 +var.yaw_speed*2, 0, 1)*var.walk  +torad( -1 -6*cos(var.ls +cos(var.ls)/1.3) )*sqrt(limb_speed)*(0.5*var.run+0.5*var.sprint)  +torad(-1 +(-3-5*sin(var.ls -cos(var.ls)     ) )*var.walk )*var.sneak                                                                               +torad(    (   -2*sin(      var.lsc +cos(      var.lsc)    ))*(0.5+0.7*var.crawl) )*var.prone  +(-var.mvmnt_llegrx/2 +torad(2)*abs(var.sidwd_drag) )*var.sidwd_drag*var.walk*var.strafe",
      "var.mvmnt_rlegtx": "(-0.05                                            )*sqrt(limb_speed)*var.run                                                                                                                                                                             +(-0.3 +(-0.3-0.5*sin(     var.lsc -cos(      var.lsc)  ) )*(0.5+0.7*var.crawl)    )*var.prone  +( var.mvmnt_rlegtz/1.5 +0.5*max(0,-var.sidwd_drag) -0.5*max(0,var.sidwd_drag) )*var.sidwd_drag*var.walk*var.strafe",
      "var.mvmnt_llegtx": "( 0.05                                            )*sqrt(limb_speed)*var.run                                                                                                                                                                             +( 0.3 +( 0.3-0.5*sin(     var.lsc +cos(      var.lsc)  ) )*(0.5+0.7*var.crawl)    )*var.prone  +( var.mvmnt_llegtz/1.5 -0.5*max(0,-var.sidwd_drag) +0.5*max(0,var.sidwd_drag) )*var.sidwd_drag*var.walk*var.strafe",
      "var.mvmnt_rlegty": "(-0.4   -2*cos(0.3 +var.ls +cos(0.2 +var.ls)*1.3) )*sqrt(limb_speed)*var.run*(1-var.in_air/1.5)*clamp(1-var.land,0,1)  -( -0.3 +clamp(-1.3*sin(var.ls +cos(-pi/4+var.ls)/2.5 ), (-0.45 +0.7*sin(pi/6+var.ls)), 3 ) )*var.walk*(1-var.run)*(1-var.in_air) +(-2   +(      3 *cos(pi/9+var.lsc -cos( pi/9+var.lsc)/2) )*(  1+0.5*var.crawl)    )*var.prone",
      "var.mvmnt_llegty": "(-0.4   +2*cos(0.3 +var.ls -cos(0.2 +var.ls)*1.3) )*sqrt(limb_speed)*var.run*(1-var.in_air/1.5)*clamp(1-var.land,0,1)  -( -0.3 +clamp( 1.3*sin(var.ls -cos(-pi/4+var.ls)/2.5 ), (-0.45 -0.7*sin(pi/6+var.ls)), 3 ) )*var.walk*(1-var.run)*(1-var.in_air) +(-2   +(     -3 *cos(pi/9+var.lsc +cos( pi/9+var.lsc)/2) )*(  1+0.5*var.crawl)    )*var.prone",
      "var.mvmnt_rlegtz": "(-2.5 +2.5*sin(0.4 +var.ls +cos(  1 +var.ls)/1.4) )*sqrt(limb_speed)*var.run*(1-var.in_air/1.5) *(1-0.1*var.strafe)    +( -1.5        +1.6*sin(var.ls +cos( pi/4+var.ls)/2.5 ) *(1-0.1*var.strafe)                 )*var.walk*(1-var.run)*(1-var.in_air) +(-3   +( 0.8+0.8*cos(     var.lsc +sin(-pi/6+var.lsc)/3) )*var.crawl -2*var.climb )*var.prone +( 0.3 +2*var.walk )*var.sneak",
      "var.mvmnt_llegtz": "(-2.5 -2.5*sin(0.4 +var.ls -cos(  1 +var.ls)/1.4) )*sqrt(limb_speed)*var.run*(1-var.in_air/1.5) *(1-0.1*var.strafe)    +( -1.5        -1.6*sin(var.ls -cos( pi/4+var.ls)/2.5 ) *(1-0.1*var.strafe)                 )*var.walk*(1-var.run)*(1-var.in_air) +(-3   +( 0.8-0.8*cos(     var.lsc -sin(-pi/6+var.lsc)/3) )*var.crawl -2*var.climb )*var.prone +( 0.3 +2*var.walk )*var.sneak",
      "var.mvmnt_rfootrx": "torad(6*(1-0.7*var.wade) +6*sin(var.ls)*var.walk )*clamp(var.sneak*(1-var.climb)+var.wade/1.5, 0, 1-var.in_air/1.5)",
      "var.mvmnt_lfootrx": "torad(6*(1-0.7*var.wade) -6*sin(var.ls)*var.walk )*clamp(var.sneak*(1-var.climb)+var.wade/1.5, 0, 1-var.in_air/1.5)",
      "var.mvmnt_rfootry": "torad(    5*var.idle +( 5-5*cos(var.ls) )*var.walk*(1-var.run) )*var.sneak*(1-var.in_air/1.5)",
      "var.mvmnt_lfootry": "torad(   -5*var.idle +(-5-5*cos(var.ls) )*var.walk*(1-var.run) )*var.sneak*(1-var.in_air/1.5)",
      "var.mvmnt_rfootrz": "torad( (-1 -2*sin(var.ls) )*var.sneak*var.walk*(1-var.run) )",
      "var.mvmnt_lfootrz": "torad( ( 1 -2*sin(var.ls) )*var.sneak*var.walk*(1-var.run) )"
    },
    {
      "var.udrwtr_bodyrx": "torad( 3.5*sin(       var.Btsw +sin(var.Btsw)/6)*(1+limb_speed) +2 )*var.tread*(1-var.swim) +torad(-11*cos(var.asw +sin(pi/8 +var.asw)/1.4 ) -11 )*var.swim*(1-var.raction/2-var.laction/2)",
      "var.udrwtr_bodyry": "torad( 5  *sin(-pi/3 +var.Btsw*2               )*(1+0.6*var.swim)  )*var.tread*( 1-clamp(-2+limb_speed*3, 0, 1)*var.gliding )*(1-var.raction/2-var.laction/2)",
      "var.udrwtr_bodyrz": "torad(     cos(-pi/3 +var.Btsw*2               )                   )*var.tread*(1-var.swim)",
      "var.udrwtr_bodytx": "-0.5*cos(pi/3 +var.Btsw*2)*clamp(-6*limb_speed, 0, 4*(1-var.swim))*var.tread",
      "var.udrwtr_bodyty": "                                                                                               ( 0.95*cos(var.asw +sin(pi/9+ var.asw)/2  )+0.15 )*var.swim*(1-var.gliding)",
      "var.udrwtr_bodytz": "(                            clamp( 6*limb_speed, 0, 4*(1-var.swim))*var.mforward )*var.tread +(-0.75*cos(var.asw -sin(pi/6+ var.asw)/5  )-0.75 )*var.swim",
      "var.udrwtr_headrx": "torad( 5*cos(var.Btsw +cos(var.Btsw)/6 )*clamp(3*limb_speed, 0, 1) )*var.tread*(1-var.swim) +torad(-50*(1-0.7*(1-cos(min(1,var.swim_up*4)*pi))/2) +8*cos(pi/4 +var.asw +sin(var.asw)/1.4*(1-0.5*var.swim_up)) )*var.swim",
      "var.udrwtr_headry": "0"
    },
    {
      "var.udrwtr_rarmrx": "( torad(-24*cos( pi/5+var.Btsw +sin( pi/5  +var.Btsw   )/(1.7+limb_speed)*var.mforward )*clamp(1+limb_speed*3, 0, 2) -10 -5*clamp(3*limb_speed, 0, 1)*var.mforward )*var.tread*(1-var.swim) +torad(-83*cos(       var.asw +sin( pi/16       +var.asw)/1.2*(1-0.5*var.swim_up) )-78 )*var.swim )*(1-var.raction-var.laction/2)",
      "var.udrwtr_larmrx": "( torad(-24*cos( pi/5+var.Btsw +sin( pi/5  +var.Btsw   )/(1.7+limb_speed)*var.mforward )*clamp(1+limb_speed*3, 0, 2) -10 -5*clamp(3*limb_speed, 0, 1)*var.mforward )*var.tread*(1-var.swim) +torad(-83*cos(       var.asw +sin( pi/16       +var.asw)/1.2*(1-0.5*var.swim_up) )-78 )*var.swim )*(1-var.laction-var.raction/2)",
      "var.udrwtr_rarmry": "( torad(-18*cos(-pi/5+var.Btsw -sin(-pi/2.5+var.Btsw   )/1.5                           )  -5*sin(-pi/3+var.Btsw*2)   -7 +14*clamp(3*limb_speed, 0, 1)              )*var.tread*(1-var.swim) +torad( 40*cos(-pi/4 +var.asw +sin(-pi/4 -pi/12 +var.asw)/1.2*(1-0.5*var.swim_up) )+24 )*var.swim )*(1-var.raction-var.laction/2)",
      "var.udrwtr_larmry": "( torad( 18*cos(-pi/5+var.Btsw -sin(-pi/2.5+var.Btsw   )/1.5                           )  -5*sin(-pi/3+var.Btsw*2)   +7 -14*clamp(3*limb_speed, 0, 1)              )*var.tread*(1-var.swim) +torad(-40*cos(-pi/4 +var.asw +sin(-pi/4 -pi/12 +var.asw)/1.2*(1-0.5*var.swim_up) )-24 )*var.swim )*(1-var.laction-var.raction/2)",
      "var.udrwtr_rarmrz": "( torad(-10*sin( pi/8+var.Btsw +sin( pi/8  +var.Btsw*2 )/5                                                                                        )*var.tread +15  )*var.water*(1-var.swim) +torad( 30*sin(       var.asw -cos( pi/10       +var.asw)*1.3*(1-0.5*var.swim_up) )+34 )*var.swim )*(1-var.raction-var.laction/2)",
      "var.udrwtr_larmrz": "( torad( 10*sin( pi/8+var.Btsw +sin( pi/8  +var.Btsw*2 )/5                                                                                        )*var.tread -15  )*var.water*(1-var.swim) +torad(-30*sin(       var.asw -cos( pi/10       +var.asw)*1.3*(1-0.5*var.swim_up) )-34 )*var.swim )*(1-var.laction-var.raction/2)",
      "var.udrwtr_rarmtx": "                                                                                                                            ( clamp( 2*cos(var.asw                   ) -0.5, -0.3, 2) )*var.swim",
      "var.udrwtr_larmtx": "                                                                                                                            ( clamp(-2*cos(var.asw                   ) +0.5, -2, 0.3) )*var.swim",
