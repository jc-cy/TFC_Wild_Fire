      "var.gldng_rlegrz": "torad( 0.5 -clamp( var.yaw_speed*10, -1, 1)/2 *var.hy*pow(var.gfast,2) +sin(age/2)/2*(var.hy/4) +0.5*cos(limb_swing*1.3)*pow(var.gfast,2) +2*cos(pi/8 +limb_swing/33 +sin(limb_swing/40)/4) +var.gliderleg_drag*17 )*var.gliding",
      "var.gldng_llegrz": "torad( 0.5 +clamp( var.yaw_speed*10, -1, 1)/2 *var.hy*pow(var.gfast,2) +sin(age/2)/2*(var.hy/4) +0.5*cos(limb_swing*1.3)*pow(var.gfast,2) +2*cos(pi/8 +limb_swing/33 +sin(limb_swing/40)/4) +var.gliderleg_drag*17 )*var.gliding",
      "var.gldng_rlegtx": "(   -cos(pi/8 +limb_swing/25 +sin(limb_swing/40)/4)    )*var.gliding",
      "var.gldng_llegtx": "(   -cos(pi/8 +limb_swing/25 +sin(limb_swing/40)/4)    )*var.gliding",
      "var.gldng_rlegty": "0",
      "var.gldng_llegty": "0",
      "var.gldng_rlegtz": "( -2*cos(pi/8 +limb_swing/33 +sin(limb_swing/40)/4) +2 +var.lleg_pitch/5 )*var.gliding",
      "var.gldng_llegtz": "( -2*cos(pi/8 +limb_swing/33 +sin(limb_swing/40)/4) +2 -var.lleg_pitch/5 )*var.gliding"
    },
    {
      "var.fly_bodyrx": "torad( 3*cos( pi/4+var.lsF )*limb_speed -15*var.speed_drag*min(0, var.forwd_drag ) -30*clamp(var.speed_speed*4*var.forwd_drag,-1,0) )*var.flying",
      "var.fly_bodyry": "0",
      "var.fly_bodyrz": "0",
