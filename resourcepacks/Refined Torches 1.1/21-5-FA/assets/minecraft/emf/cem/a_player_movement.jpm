      "var.vrtcl_rarmrx": "torad( (-60*exp(-var.t_jump*pi)*limb_speed*var.mforward*(1-var.sprint) +(30*cos(var.t_jump*pi))*(var.prone-var.climb) )*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint))*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*var.jump*min(1, var.water +var.prone ) +( (15+45*pow(limb_speed,2))*sin(var.t_Rjump*pi) )*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint))*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*var.Rjump*(1-var.prone) +( (-20-60*pow(limb_speed,2))*sin(var.t_Ljump*pi) )*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*var.Ljump*(1-var.prone)*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint)) +( -5 +10*limb_speed +30*sin(var.lsj)*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint))                )*var.fall*(1-var.raction)*(1-var.tread) +( 30*sin(-pi/6+var.t_land*4)*var.idle*var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern)) -5*exp(cos(-pi/4+var.t_land*pi))*var.prone )*var.land )",
      "var.vrtcl_rarmry": "torad(                                                                                                                                                         +( -10                      *sin(var.t_Rjump*pi) )*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*var.Rjump*(1-var.prone) +(  -20                      *sin(var.t_Ljump*pi) )*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*var.Ljump*(1-var.prone)                  +(     30*limb_speed -10*sin(var.lsj)*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint)) +30*var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern)) )*var.fall*(1-var.raction)*max(0,1-var.swim-var.sprjmp-var.prone) )",
      "var.vrtcl_rarmrz": "torad(                                                                                                                                                                                                                                                                                                                                 +(     100           -10*cos(var.lsj)*(1-var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern))/(2+0.8*var.sprint)) -30*var.requip*(1-var.torch_fall*(var.rholdtorch+var.rholdlantern)) )*var.fall*(1-var.raction)*max(0,1-var.swim-var.sprjmp-var.prone) +( 10*abs(cos(var.t_land*pi)) -3 )*var.land )",
      "var.vrtcl_larmrx": "torad( (-60*exp(-var.t_jump*pi)*limb_speed*var.mforward*(1-var.sprint) +(30*cos(var.t_jump*pi))*(var.prone-var.climb) )*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint))*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*var.jump*min(1, var.water +var.prone ) +( (15+45*pow(limb_speed,2))*sin(var.t_Ljump*pi) )*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint))*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*var.Ljump*(1-var.prone) +( (-20-60*pow(limb_speed,2))*sin(var.t_Rjump*pi) )*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*var.Rjump*(1-var.prone)*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint)) +( -5 +10*limb_speed -30*sin(var.lsj)*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint))                )*var.fall*(1-var.laction)*(1-var.tread) +( 30*sin(-pi/6+var.t_land*4)*var.idle*var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern)) -5*exp(cos(-pi/4+var.t_land*pi))*var.prone )*var.land )",
      "var.vrtcl_larmry": "torad(                                                                                                                                                         +(  10                      *sin(var.t_Ljump*pi) )*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*var.Ljump*(1-var.prone) +(   20                      *sin(var.t_Rjump*pi) )*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*var.Rjump*(1-var.prone)                  +(    -30*limb_speed -10*sin(var.lsj)*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint)) -30*var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern)) )*var.fall*(1-var.laction)*max(0,1-var.swim-var.sprjmp-var.prone) )",
      "var.vrtcl_larmrz": "torad(                                                                                                                                                                                                                                                                                                                                 +(    -110           -10*cos(var.lsj)*(1-var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern))/(2+0.8*var.sprint)) +30*var.lequip*(1-var.torch_fall*(var.lholdtorch+var.lholdlantern)) )*var.fall*(1-var.laction)*max(0,1-var.swim-var.sprjmp-var.prone) -( 10*abs(cos(var.t_land*pi)) -3 )*var.land )",
      "var.vrtcl_rarmtz": "var.vrtcl_rarmrx*2*var.fall*(1-var.raction) +(-3*cos(var.t_jump*2))*(var.prone-var.climb)*var.jump +( 2.5*pow(limb_speed,2) )*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)*(var.Rjump-var.Ljump)",
      "var.vrtcl_larmtz": "var.vrtcl_larmrx*2*var.fall*(1-var.laction) +(-3*cos(var.t_jump*2))*(var.prone-var.climb)*var.jump +( 2.5*pow(limb_speed,2) )*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)*(var.Ljump-var.Rjump)",
      "var.vrtcl_rarmtx": "(-var.fall*(1-var.swim)*(1-var.raction) +0.5*pow(limb_speed,2)*var.Ljump)*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)",
      "var.vrtcl_larmtx": "( var.fall*(1-var.swim)*(1-var.laction) -0.5*pow(limb_speed,2)*var.Ljump)*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)",
      "var.vrtcl_rarmty": "(-cos(pi/4+var.t_land*3)*var.land +( -var.vrtcl_rarmrz )*var.fall +( 0.3-sin(var.ls) )/2*sin(var.t_jump*pi)*var.jump*min(1, var.water +var.prone ) +( -1 )*var.Ljump)*clamp(1-(var.rholdtorch+var.rholdlantern),0,1)",
      "var.vrtcl_larmty": "(-cos(pi/4+var.t_land*3)*var.land +(  var.vrtcl_larmrz )*var.fall +( 0.3+sin(var.ls) )/2*sin(var.t_jump*pi)*var.jump*min(1, var.water +var.prone ) +( -1 )*var.Rjump)*clamp(1-(var.lholdtorch+var.lholdlantern),0,1)",
      "var.idl_rarmrx": "var.idl_rarmrx+torad(-if(is_right_handed,var.headyaw_drag/6*var.requip,0))*var.idle*(var.rholdtorch+var.rholdlantern)",
      "var.idl_larmrx": "var.idl_larmrx+torad(-if(!is_right_handed,var.headyaw_drag/6*var.lequip,0))*var.idle*(var.lholdtorch+var.lholdlantern)",
      "var.right_item_rx": "var.right_item_rx+torad(-18*sin(limb_swing*0.6662)*limb_speed)*var.rholdlantern*(1-var.torch_fall)",
      "var.right_item_ry": "var.right_item_ry+torad(18*clamp(var.yaw_speed*3,-1,1))*var.rholdlantern*(1-var.torch_fall)+torad(-15*var.strafe*limb_speed)*var.rholdlantern*(1-var.torch_fall)",
      "var.right_item_rz": "var.right_item_rz+torad(10*clamp(var.yaw_speed*3,-1,1))*var.rholdlantern*(1-var.torch_fall)+torad(10*var.strafe*limb_speed)*var.rholdlantern*(1-var.torch_fall)",
      "var.left_item_rx": "var.left_item_rx+torad(-18*sin(limb_swing*0.6662)*limb_speed)*var.lholdlantern*(1-var.torch_fall)",
      "var.left_item_ry": "var.left_item_ry+torad(-18*clamp(var.yaw_speed*3,-1,1))*var.lholdlantern*(1-var.torch_fall)+torad(-15*var.strafe*limb_speed)*var.lholdlantern*(1-var.torch_fall)",
      "var.left_item_rz": "var.left_item_rz+torad(10*clamp(var.yaw_speed*3,-1,1))*var.lholdlantern*(1-var.torch_fall)+torad(10*var.strafe*limb_speed)*var.lholdlantern*(1-var.torch_fall)"
    }
  ]
}